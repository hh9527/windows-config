{
  "schema": 1,
  "packages": {
    "main": {
      "variables": [
        {
          "commit": {
            "src": "https://github.com/hh9527/windows-config/commits/main.atom",
            "ty": "CommitFromGithubAtom"
          }
        }
      ],
      "install": [
        {
          "action": "InstallMainConfig",
          "file": "windows-config-<commit>.tar.gz",
          "src": "https://github.com/hh9527/windows-config/archive/<commit>.tar.gz"
        }
      ]
    },
    "spmw": {
      "variables": [
        {
          "version": {
            "src": "https://github.com/hh9527/spmw/releases/latest/download/VERSION.txt"
          }
        }
      ],
      "install": [
        {
          "action": "Unpack",
          "src": "https://github.com/hh9527/spmw/releases/download/<version>/tarball.tar.gz",
          "verify": {
            "sha256": {
              "src": "https://github.com/hh9527/spmw/releases/download/<version>/sha256.txt"
            }
          }
        }
      ]
    },
    "CascadiaNextSC": {
      "variables": [
        {
          "version": "1.0.1"
        }
      ],
      "install": [
        {
          "action": "InstallFonts",
          "src": "https://github.com/LiLittleCat/Cascadia-Next-Nerd-Font/releases/download/v<version>/CascadiaNextSCNF-ttc.tar.gz"
        }
      ]
    },
    "WezTerm": {
      "variables": [
        {
          "sha256": {
            "src": "https://github.com/wezterm/wezterm/releases/download/nightly/WezTerm-windows-nightly.zip.sha256"
          }
        },
        {
          "version": "nightly-<sha256>"
        }
      ],
      "install": [
        {
          "action": "Unpack",
          "file": "WezTerm-<sha256>.zip",
          "src": "https://github.com/wezterm/wezterm/releases/download/nightly/WezTerm-windows-nightly.zip",
          "verify": {
            "sha256": "<sha256>"
          },
          "strip": 1
        }
      ]
    },
    "TermSCP": {
      "variables": [
        {
          "version": "1.1.1"
        }
      ],
      "install": [
        {
          "action": "Unpack",
          "src": "https://github.com/veeso/termscp/releases/download/v<version>/termscp-v<version>-x86_64-pc-windows-msvc.zip"
        }
      ]
    }
  },
  "links": {
    "bin:spmw-cli.ps1": "pkgs.spmw:bin/spmw-cli.ps1",
    "user:.wezterm.lua": "pkgs.main:user/.wezterm.lua",
    "bin:termscp.exe": "pkgs.TermSCP:termscp.exe"
  },
  "shortcuts": {
    "apps:WezTerm": {
      "program": "pkgs.WezTerm:wezterm-gui.exe",
      "cwd": "pkgs.WezTerm"
    }
  }
}
